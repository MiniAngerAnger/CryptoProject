# ── CryptoProject 环境变量模板 ──
# 复制本文件为 .env，填入真实值，.env 已在 .gitignore 中忽略

# Etherscan API Key（链上监控必须）
# 注册地址：https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# NewsAPI Key（L2 新闻情绪采集）
# 注册地址：https://newsapi.org/account
# 免费版限额：100 requests/day，间隔 3600s 默认配置安全使用
NEWSAPI_KEY=

# Telegram（如启用链上鲸鱼告警）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 以下为预留
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
GEMINI_API_KEY=
